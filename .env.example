# ============================================
# SUPABASE (pegue em Project Settings > API)
# ============================================
# URL do seu projeto Supabase
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# anon/public key - vai pro frontend, é seguro pois é protegida pelo RLS
VITE_SUPABASE_ANON_KEY=coloque_aqui_a_anon_key

# service_role key - NUNCA exponha no frontend, usada só nas funções serverless (/api)
SUPABASE_SERVICE_ROLE_KEY=coloque_aqui_a_service_role_key

# ============================================
# IFOOD (pegue no Portal do Desenvolvedor > Meus Apps > Credenciais)
# ============================================
IFOOD_CLIENT_ID=coloque_aqui_o_client_id
IFOOD_CLIENT_SECRET=coloque_aqui_o_client_secret

# IDs das suas 3 lojas (merchantId), separados por vírgula, sem espaço
# Pegue em GET /merchant/v1.0/merchants depois de autorizar as lojas
IFOOD_MERCHANT_IDS=merchantId1,merchantId2,merchantId3

# ============================================
# LIMPEZA AUTOMÁTICA (opcional, mas recomendado)
# ============================================
# Qualquer valor aleatório serve. A Vercel envia esse valor automaticamente
# no header Authorization do cron job - não precisa fazer nada além de
# definir essa variável. Gere um valor com, por exemplo: openssl rand -hex 32
CRON_SECRET=coloque_aqui_um_valor_aleatorio
